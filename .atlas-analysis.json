  "keyFeatures": [
    "Scrape - Convert URLs to markdown, HTML, or structured JSON",
    "Crawl - Scrape entire websites with configurable depth and limits",
    "Map - Discover all URLs on a website instantly",
    "Search - Search the web and scrape results",
    "Agent - Autonomous data gathering with AI",
    "Batch Scrape - Process multiple URLs asynchronously",
    "Actions - Interact with pages before scraping (click, scroll, type)",
    "Formats - Multiple output formats (markdown, HTML, JSON, screenshots)",
    "Webhooks - Real-time notifications for async operations",
    "Deep Research - Multi-depth research with source analysis"
  ],
  "publicApiSurface": [
    "POST /v1/scrape - Scrape a single URL",
    "POST /v1/batch/scrape - Batch scrape multiple URLs",
    "GET /v1/batch/scrape/{id} - Get batch scrape status",
    "DELETE /v1/batch/scrape/{id} - Cancel batch scrape",
    "GET /v1/batch/scrape/{id}/errors - Get batch scrape errors",
    "POST /v1/crawl - Start a crawl job",
    "GET /v1/crawl/{id} - Get crawl status",
    "DELETE /v1/crawl/{id} - Cancel crawl",
    "GET /v1/crawl/{id}/errors - Get crawl errors",
    "GET /v1/crawl/active - Get active crawls",
    "POST /v1/map - Map website URLs",
    "POST /v1/search - Search the web",
    "POST /v1/agent - AI agent for data gathering",
    "POST /v1/extract - Extract structured data",
    "GET /v1/extract/{id} - Get extraction status",
    "POST /v1/deep-research - Start deep research",
    "GET /v1/deep-research/{id} - Get research status",
    "GET /v1/team/credit-usage - Get credit usage"
  ]
}
